---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="作品管理 - 后台">
  <section class="min-h-screen bg-gradient-to-br from-neutral-50 via-indigo-50 to-purple-50 dark:from-gray-950 dark:via-gray-900 dark:to-gray-950 px-4 py-8">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-2">
          <a href="/admin" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-primary">← 返回后台首页</a>
        </div>
        <h1 class="text-3xl font-bold text-neutral-900 dark:text-white">作品管理</h1>
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mt-1">管理 My Works 页面展示的作品集</p>
      </div>

      <!-- Token Input -->
      <div class="admin-card mb-6">
        <label class="block">
          <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300">管理员 Token</span>
          <input
            id="admin-token"
            type="password"
            placeholder="请输入管理员 Token"
            class="mt-1 w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-gray-800 px-4 py-2 text-sm"
          />
        </label>
        <div id="admin-status" class="mt-2 text-sm"></div>
      </div>

      <!-- Works List -->
      <div class="admin-card mb-6">
        <h2 class="text-xl font-semibold mb-4 text-neutral-900 dark:text-white">作品列表</h2>
        <div id="works-list"></div>
      </div>

      <!-- Works Form -->
      <div class="admin-card">
        <h2 class="text-xl font-semibold mb-4 text-neutral-900 dark:text-white">
          <span id="form-title">新增作品</span>
        </h2>
        <form id="work-form" class="admin-form">
          <input name="id" type="hidden" />
          <div class="form-grid">
            <label>
              <span class="text-sm font-medium">作品名称 *</span>
              <input name="name" type="text" required />
            </label>
            <label>
              <span class="text-sm font-medium">链接地址 *</span>
              <input name="url" type="text" placeholder="https://example.com 或 www.example.com" required />
            </label>
            <label class="col-span-2">
              <span class="text-sm font-medium">描述</span>
              <textarea name="description" rows="3" placeholder="作品简介..."></textarea>
            </label>
            <label>
              <span class="text-sm font-medium">封面图片</span>
              <input type="hidden" name="imagePath" />
              <input
                type="file"
                accept="image/*"
                data-upload-target="imagePath"
                data-upload-category="works-image"
                data-upload-status="#work-image-status"
              />
              <p id="work-image-status" class="upload-status">尚未上传</p>
            </label>
            <label>
              <span class="text-sm font-medium">视频（可选）</span>
              <input type="hidden" name="videoPath" />
              <input
                type="file"
                accept="video/*"
                data-upload-target="videoPath"
                data-upload-category="works-video"
                data-upload-status="#work-video-status"
              />
              <p id="work-video-status" class="upload-status">尚未上传</p>
            </label>
            <label>
              <span class="text-sm font-medium">标签（逗号分隔）</span>
              <input name="tags" type="text" placeholder="设计, 开发, UI/UX" />
            </label>
            <label>
              <span class="text-sm font-medium">排序</span>
              <input name="sortOrder" type="number" value="0" />
            </label>
            <label class="checkbox-label">
              <input name="isShow" type="checkbox" checked />
              <span class="text-sm font-medium">在前台显示</span>
            </label>
          </div>
          <div class="flex flex-wrap gap-3 mt-6">
            <button type="submit" class="admin-button">保存作品</button>
            <button type="button" data-reset-work class="admin-secondary">重置表单</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</MainGridLayout>

<style>
  .admin-card {
    border-radius: 1.25rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.95);
    padding: 1.75rem;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
  }

  :global(.dark) .admin-card {
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(15, 23, 42, 0.8);
  }

  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .form-grid label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.9rem;
    color: rgb(15 23 42);
  }

  :global(.dark) .form-grid label {
    color: rgb(226 232 240);
  }

  .form-grid input,
  .form-grid textarea {
    border-radius: 0.75rem;
    border: 1px solid rgba(15, 23, 42, 0.15);
    padding: 0.65rem 0.85rem;
    font-size: 0.9rem;
    background: rgba(255, 255, 255, 0.95);
    color: rgb(15 23 42);
  }

  :global(.dark) .form-grid input,
  :global(.dark) .form-grid textarea {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(15, 23, 42, 0.7);
    color: rgb(226 232 240);
  }

  .admin-button {
    border-radius: 999px;
    padding: 0.65rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(120deg, #6366f1, #ec4899);
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .admin-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
  }

  .admin-secondary {
    border-radius: 999px;
    padding: 0.65rem 1.5rem;
    font-size: 0.85rem;
    border: 1px solid rgba(15, 23, 42, 0.15);
    background: transparent;
    cursor: pointer;
  }

  .checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
  }

  .upload-status {
    font-size: 0.75rem;
    color: rgb(100 116 139);
    margin-top: 0.25rem;
  }

  .col-span-2 {
    grid-column: span 2;
  }

  .admin-table-wrapper {
    border-radius: 0.75rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    overflow-x: auto;
    max-height: 500px;
    overflow-y: auto;
  }

  :global(.admin-table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  :global(.admin-table th),
  :global(.admin-table td) {
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }

  :global(.admin-table th) {
    background: rgba(99, 102, 241, 0.08);
    font-weight: 600;
    color: rgb(45 55 72);
    position: sticky;
    top: 0;
    z-index: 10;
    font-size: 0.8rem;
  }

  :global(.admin-table tbody tr:hover) {
    background: rgba(99, 102, 241, 0.03);
  }

  :global(.admin-table-actions) {
    display: flex;
    gap: 0.35rem;
    flex-wrap: nowrap;
  }

  :global(.admin-table-actions button) {
    border-radius: 0.375rem;
    border: 1px solid rgba(99, 102, 241, 0.25);
    background: white;
    color: rgb(99 102 241);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    white-space: nowrap;
    transition: all 0.2s;
    cursor: pointer;
  }

  :global(.admin-table-actions button:hover) {
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.4);
  }

  :global(.dark) .admin-table-wrapper {
    border-color: rgba(255, 255, 255, 0.12);
  }

  :global(.dark) :global(.admin-table th) {
    background: rgba(99, 102, 241, 0.15);
    color: rgb(226 232 240);
  }

  :global(.dark) :global(.admin-table td) {
    border-color: rgba(255, 255, 255, 0.08);
    color: rgb(226 232 240);
  }

  :global(.dark) :global(.admin-table-actions button) {
    background: rgba(15, 23, 42, 0.6);
    color: rgb(226 232 240);
    border-color: rgba(99, 102, 241, 0.3);
  }

  :global(.dark) :global(.admin-table-actions button:hover) {
    background: rgba(99, 102, 241, 0.2);
    border-color: rgba(99, 102, 241, 0.5);
  }

  :global(.dark) :global(.admin-table tbody tr:hover) {
    background: rgba(99, 102, 241, 0.08);
  }
</style>

<script>
  import initAdminDashboard from "@/scripts/admin-dashboard";
  initAdminDashboard();
</script>
