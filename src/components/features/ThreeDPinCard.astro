---
export interface Props {
	title: string;
	href: string;
	imgurl: string;
	desc: string;
	tags?: string[];
}

const { title, href, imgurl, desc, tags = [] } = Astro.props;
---

<three-d-pin class="pin-wrapper" data-href={href}>
  <div class="pin-container">
    <!-- 3D perspective card -->
    <div class="pin-perspective">
      <div class="pin-card-face">
        <div class="pin-content">
          <h3 class="pin-title">{title}</h3>
          <p class="pin-desc">{desc}</p>
          <div class="pin-image-wrap">
            <img
              src={imgurl}
              alt={title}
              class="pin-image"
              loading="lazy"
            />
          </div>
          {tags.length > 0 && (
            <div class="pin-tags">
              {tags.slice(0, 3).map((tag) => (
                <span class="pin-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Pin perspective overlay (visible on hover) -->
    <div class="pin-overlay">
      <!-- Title pill -->
      <div class="pin-pill-wrap">
        <span class="pin-pill">
          <span class="pin-pill-text">{title}</span>
          <span class="pin-pill-glow"></span>
        </span>
      </div>

      <!-- Pulsing rings -->
      <div class="pin-rings">
        <div class="pin-ring pin-ring-1"></div>
        <div class="pin-ring pin-ring-2"></div>
        <div class="pin-ring pin-ring-3"></div>
      </div>

      <!-- Beam line -->
      <div class="pin-beam pin-beam-blur"></div>
      <div class="pin-beam pin-beam-solid"></div>
      <div class="pin-dot pin-dot-blur"></div>
      <div class="pin-dot pin-dot-solid"></div>
    </div>
  </div>
</three-d-pin>

<script>
  if (!customElements.get("three-d-pin")) {
    class ThreeDPin extends HTMLElement {
      private cardFace: HTMLElement | null = null;

      connectedCallback() {
        this.cardFace = this.querySelector(".pin-card-face");
        if (!this.cardFace) return;

        this.addEventListener("mouseenter", this.onEnter);
        this.addEventListener("mouseleave", this.onLeave);
        this.addEventListener("click", this.onClick);
      }

      disconnectedCallback() {
        this.removeEventListener("mouseenter", this.onEnter);
        this.removeEventListener("mouseleave", this.onLeave);
        this.removeEventListener("click", this.onClick);
      }

      private onEnter = () => {
        if (this.cardFace) {
          this.cardFace.style.transform =
            "translate(-50%,-50%) rotateX(40deg) scale(0.8)";
        }
      };

      private onLeave = () => {
        if (this.cardFace) {
          this.cardFace.style.transform =
            "translate(-50%,-50%) rotateX(0deg) scale(1)";
        }
      };

      private onClick = () => {
        const href = this.dataset.href;
        if (href) window.open(href, "_blank", "noopener,noreferrer");
      };
    }
    customElements.define("three-d-pin", ThreeDPin);
  }
</script>

<style is:global>
  /* ========== Wrapper ========== */
  .pin-wrapper {
    display: block;
    position: relative;
    z-index: 1;
    cursor: pointer;
    height: 18rem;
    width: 100%;
  }

  .pin-wrapper:hover {
    z-index: 50;
  }

  .pin-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* ========== 3D Card Face ========== */
  .pin-perspective {
    perspective: 1000px;
    transform: rotateX(70deg) translateZ(0deg);
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    margin-left: 0.09375rem;
    margin-top: 0.25rem;
  }

  .pin-card-face {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) rotateX(0deg) scale(1);
    padding: 1rem;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    border-radius: 1rem;
    box-shadow:
      0 8px 16px rgb(0 0 0 / 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.05);
    background: oklch(0.15 0 0);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 700ms cubic-bezier(0.23, 1, 0.32, 1);
    overflow: hidden;
    width: 14rem;
    height: 18rem;
  }

  :root:not(.dark) .pin-card-face {
    background: oklch(0.98 0 0);
    border-color: oklch(0.88 0 0);
    box-shadow:
      0 8px 16px rgb(0 0 0 / 0.1),
      0 0 0 1px oklch(0.9 0 0);
  }

  .pin-wrapper:hover .pin-card-face {
    border-color: rgba(255, 255, 255, 0.15);
  }

  :root:not(.dark) .pin-wrapper:hover .pin-card-face {
    border-color: oklch(0.75 0 0);
  }

  @media (min-width: 640px) {
    .pin-card-face {
      width: 16rem;
      height: 19rem;
    }
  }

  /* ========== Card Content ========== */
  .pin-content {
    position: relative;
    z-index: 50;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    padding: 0.25rem;
  }

  .pin-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: oklch(0.95 0 0);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :root:not(.dark) .pin-title {
    color: oklch(0.15 0 0);
  }

  .pin-desc {
    margin: 0.5rem 0 0;
    font-size: 0.8125rem;
    font-weight: 400;
    color: oklch(0.6 0 0);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.4em;
  }

  :root:not(.dark) .pin-desc {
    color: oklch(0.45 0 0);
  }

  .pin-image-wrap {
    margin-top: 0.75rem;
    flex: 1;
    width: 100%;
    min-height: 8rem;
    border-radius: 0.75rem;
    overflow: hidden;
    background: oklch(0.2 0 0);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  :root:not(.dark) .pin-image-wrap {
    background: oklch(0.93 0 0);
    border-color: oklch(0.88 0 0);
  }

  .pin-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pin-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .pin-tag {
    font-size: 0.625rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.06);
    color: oklch(0.6 0 0);
    line-height: 1.5;
  }

  :root:not(.dark) .pin-tag {
    background: oklch(0.92 0 0);
    color: oklch(0.45 0 0);
  }

  /* ========== Hover Overlay ========== */
  .pin-overlay {
    pointer-events: none;
    width: 24rem;
    height: 20rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    z-index: 60;
    transition: opacity 500ms;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .pin-wrapper:hover .pin-overlay {
    opacity: 1;
  }

  /* ========== Title Pill ========== */
  .pin-pill-wrap {
    position: absolute;
    top: 1.5rem;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
  }

  .pin-pill {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 1rem;
    border-radius: 9999px;
    background: oklch(0.15 0 0);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  :root:not(.dark) .pin-pill {
    background: oklch(0.2 0 0);
  }

  .pin-pill-text {
    position: relative;
    z-index: 20;
    color: oklch(0.95 0 0);
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .pin-pill-glow {
    position: absolute;
    bottom: -1px;
    left: 1.125rem;
    width: calc(100% - 2.25rem);
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      oklch(0.7 0.05 200 / 0.6),
      transparent
    );
    transition: opacity 500ms;
  }

  .pin-wrapper:hover .pin-pill-glow {
    opacity: 0.4;
  }

  /* ========== Pulsing Rings ========== */
  .pin-rings {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) perspective(1000px) rotateX(70deg) translateZ(0);
    width: 11.25rem;
    height: 11.25rem;
  }

  .pin-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 11.25rem;
    height: 11.25rem;
    border-radius: 50%;
    background: oklch(0.6 0.02 200 / 0.06);
    box-shadow: 0 8px 16px rgb(0 0 0 / 0.4);
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
  }

  :root:not(.dark) .pin-ring {
    background: oklch(0.5 0.02 200 / 0.08);
  }

  .pin-wrapper:hover .pin-ring-1 {
    animation: pinPulse 6s infinite 0s;
  }
  .pin-wrapper:hover .pin-ring-2 {
    animation: pinPulse 6s infinite 2s;
  }
  .pin-wrapper:hover .pin-ring-3 {
    animation: pinPulse 6s infinite 4s;
  }

  @keyframes pinPulse {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0);
    }
    16.6% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(1);
    }
  }

  /* ========== Beam Line ========== */
  .pin-beam {
    position: absolute;
    right: 50%;
    bottom: 50%;
    transform: translateY(14px);
    width: 1px;
    height: 5rem;
    background: linear-gradient(
      to bottom,
      transparent,
      oklch(0.7 0.04 200)
    );
    transition: height 500ms;
  }

  .pin-wrapper:hover .pin-beam {
    height: 10rem;
  }

  .pin-beam-blur {
    filter: blur(2px);
  }

  .pin-beam-solid {
    /* no filter */
  }

  .pin-dot {
    position: absolute;
    right: 50%;
    bottom: 50%;
    transform: translate(0.5px, 14px);
    border-radius: 50%;
    z-index: 40;
  }

  .pin-dot-blur {
    width: 4px;
    height: 4px;
    background: oklch(0.5 0.04 200);
    filter: blur(3px);
    transform: translate(1.5px, 14px);
  }

  .pin-dot-solid {
    width: 2px;
    height: 2px;
    background: oklch(0.8 0.04 200);
    transform: translate(0.5px, 14px);
  }
</style>
