---
import { Icon } from "astro-icon/components";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import TypewriterText from "@/components/features/TypewriterText.astro";
import { profileConfig } from "@/config/profileConfig";
import { url } from "@/utils/url-utils";
---

<div class="section p-3 flex flex-col items-center gap-4">
  <a
    aria-label="Go to About Page"
    href={url("/about/")}
    class="group block relative w-60 h-60 overflow-hidden rounded-full border border-(--line-divider) shrink-0"
  >
    <ImageWrapper
      src={profileConfig.avatar || ""}
      alt="Profile Image of the Author"
      class="w-full h-full"
      loading="eager"
      fetchpriority="high"
      widths={[400]}
      sizes="400px"
    />
  </a>
  <div class="text-center w-full">
    <TypewriterText text={profileConfig.bio || ""} speed={80} pauseTime={3000} class="text-xl text-(--content-meta)" />
  </div>
  <div class="flex items-center justify-center gap-3">
    {profileConfig.links.map(item => {
      if (item.url.startsWith("mailto:")) {
        const encodedEmail = Buffer.from(item.url.replace("mailto:", "")).toString("base64");
        return <a rel="me" aria-label={item.name} href="#" data-encoded-email={encodedEmail} onclick={`(function(){const e=this.getAttribute('data-encoded-email');this.href='mailto:'+atob(e);this.removeAttribute('data-encoded-email');this.removeAttribute('onclick');this.click();return false}).call(this);`} class="w-10 h-10 flex items-center justify-center rounded-full border border-(--line-divider) text-(--deep-text) hover:text-(--primary) hover:border-(--primary) transition-colors">
          <Icon name={item.icon} class="text-xl" is:inline />
        </a>;
      }
      return <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="w-10 h-10 flex items-center justify-center rounded-full border border-(--line-divider) text-(--deep-text) hover:text-(--primary) hover:border-(--primary) transition-colors">
        <Icon name={item.icon} class="text-xl" is:inline />
      </a>;
    })}
  </div>
</div>
